# --- Backend selection ---
# "local"      → Ollama on GPU, free, use for dev/demo
# "anthropic"  → Claude Vision API, use for MVP/prod
VLM_BACKEND=local

# --- Local (Ollama) ---
LOCAL_MODEL=llava:7b
OLLAMA_URL=http://localhost:11434

# --- Anthropic (fill in before switching) ---
ANTHROPIC_API_KEY=sk-ant-...
VLM_MODEL=claude-sonnet-4-6

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
